# Home Assistant Connection
HA_URL=http://home-assistant:8123
WEBHOOK_ID=your-webhook-id-here

# Server URL (used for callback notifications)
# This is the URL that Home Assistant will use to reach this server
# Examples:
#   Docker/K8s: http://weekly-reminders:32123
#   Local dev:  http://localhost:32123
#   IP address: http://192.168.1.100:32123
SERVER_URL=http://weekly-reminders:32123
