{
	"name": "weekly-reminders",
	"version": "1.0.0",
	"description": "Home Assistant scheduler app for TrueNAS",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"dev": "concurrently \"vite\" \"bun src/index.ts\"",
		"dev:server": "bun src/index.ts",
		"dev:client": "vite",
		"build": "vite build && bun src/index.ts",
		"build:client": "vite build",
		"start": "bun src/index.ts",
		"check": "bunx biome check src/",
		"format": "bunx biome format --write ."
	},
	"keywords": ["truenas", "home-assistant", "scheduler"],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.8",
		"@js-temporal/polyfill": "^0.5.1",
		"@radix-ui/react-dialog": "^1.0.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"express": "^4.18.2",
		"lucide-react": "^1.14.0",
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.3",
		"@types/express": "^4.17.21",
		"@types/node": "^22.10.1",
		"@types/react": "^18.2.43",
		"@types/react-dom": "^18.2.17",
		"@vitejs/plugin-react": "^4.2.1",
		"autoprefixer": "^10.4.16",
		"bun-types": "latest",
		"concurrently": "^8.2.2",
		"postcss": "^8.4.32",
		"shadcn": "^4.7.0",
		"tailwindcss": "^3.4.1",
		"typescript": "^5.3.3",
		"vite": "^5.0.8"
	}
}
